OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
TAVILY_API_KEY=
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=
LANGSMITH_TRACING=

# multiroute.ai — OpenAI-compatible proxy (https://multiroute.ai)
# Set OPENAI_API_KEY to your multiroute invoke-scoped key and BASE_URL to the
# endpoint below. Then use "openai:<provider>/<model>" strings in the model
# config fields, e.g.:
#   research_model=openai:anthropic/claude-sonnet-4
#   summarization_model=openai:openai/gpt-4.1-mini
#   compression_model=openai:openai/gpt-4.1
#   final_report_model=openai:openai/gpt-4.1
# BASE_URL=https://multiroute.ai/openai/v1
# For local platform dev: BASE_URL=http://localhost:8000/openai/v1
BASE_URL=

# Only necessary for Open Agent Platform
SUPABASE_KEY=
SUPABASE_URL=
# Should be set to true for a production deployment on Open Agent Platform. Should be set to false otherwise, such as for local development.
GET_API_KEYS_FROM_CONFIG=false